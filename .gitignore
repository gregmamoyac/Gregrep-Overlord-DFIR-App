.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Credentials (never commit)
config/credentials.txt
config/*.key
config/*.pem
